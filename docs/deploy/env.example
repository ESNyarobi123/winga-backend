# Winga — Database & deployment (copy to .env and fill)
# cp env.example .env

# ─── MySQL (container / server) ─────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=StrongRootPass123!
MYSQL_DATABASE=winga_db
MYSQL_USER=winga
MYSQL_PASSWORD=WingaDbPass456!

# ─── Backend (Spring) ──────────────────────────────────────────────────────
# Backend uses: DB_USERNAME=${MYSQL_USER}, DB_PASSWORD=${MYSQL_PASSWORD}
# SPRING_DATASOURCE_URL is set in docker-compose from MYSQL_DATABASE
JWT_SECRET=your-jwt-secret-min-32-chars
APP_CORS_ALLOWED_ORIGINS=https://yourdomain.co.tz,https://admin.yourdomain.co.tz
REFERRAL_BASE_URL=https://yourdomain.co.tz

# ─── Optional ───────────────────────────────────────────────────────────────
# SPRING_PROFILES_ACTIVE=prod
# NEXT_PUBLIC_API_URL=https://api.yourdomain.co.tz
